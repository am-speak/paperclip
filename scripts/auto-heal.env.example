# =============================================================================
# Auto-Heal Configuration Example
#
# Copy this file to auto-heal.env and source it before running auto-heal.sh,
# or set these variables in your environment/systemd unit/cron job.
# =============================================================================

# ── Routes to monitor (space-separated URLs) ──────────────────────────────────
# Used in legacy mode (without --routes flag).
AUTO_HEAL_ROUTES="
  http://localhost:3100/api/health
  http://localhost:3100/api/performance/overview
"

# ── Base URL for API endpoints (used with --routes flag) ──────────────────────
# AUTO_HEAL_BASE_URL="http://localhost:3100"

# ── Recovery commands (semicolon-separated) ───────────────────────────────────
AUTO_HEAL_RECOVERY_CMDS="pnpm install --frozen-lockfile;pnpm build;systemctl --user restart paperclip-server"

# ── Failure threshold ─────────────────────────────────────────────────────────
AUTO_HEAL_MAX_ATTEMPTS=3

# ── Verification wait ─────────────────────────────────────────────────────────
AUTO_HEAL_VERIFY_WAIT=5

# ── Paperclip API (for escalation + status updates) ──────────────────────────
# PAPERCLIP_API_URL="http://localhost:3100"
# PAPERCLIP_API_KEY="sk-..."
# PAPERCLIP_RUN_ID="<current-run-id>"
# PAPERCLIP_TASK_ID="<issue-id-for-status>"
# PAPERCLIP_COMPANY_ID="<company-id>"

# ── State directory (must be writable) ────────────────────────────────────────
# AUTO_HEAL_STATE_DIR="/tmp/auto-heal"

# ── Usage examples ───────────────────────────────────────────────────────────
#
# 1. Single check cycle (cron: */5 * * * *):
#    source /path/to/auto-heal.env && /path/to/scripts/auto-heal.sh --once
#
# 2. Continuous monitoring with per-route health (systemd service):
#    /path/to/scripts/auto-heal.sh --routes
#
# 3. Monitor specific URLs (legacy mode):
#    /path/to/scripts/auto-heal.sh
#
# 4. Manual dry-run test:
#    /path/to/scripts/auto-heal.sh --once --dry-run --verbose
